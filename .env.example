# Copy to .env and fill in values.

# Port the wiki is exposed on (default: 8000)
PORT=8000

# ── LLM backend (optional) ───────────────────────────────────────────────────
# Leave LLM_BASE_URL empty to run without LLM support (browse-only mode).

# --- Option A: Ollama (local, no API key needed) ---
# Start with:  docker compose --profile ollama up
# Pull model:  docker compose exec ollama ollama pull llama3.2
#
# LLM_BASE_URL=http://ollama:11434
# LLM_MODEL=llama3.2
# LLM_API_KEY=

# --- Option B: LiteLLM proxy (multi-provider) ---
# Copy litellm-config.example.yaml → litellm-config.yaml, configure it,
# then start with:  docker compose --profile litellm up
#
# LLM_BASE_URL=http://litellm:4000
# LLM_MODEL=gpt-4o          # or whichever model LiteLLM is proxying
# LLM_API_KEY=              # set if you configured a master key in LiteLLM

# --- Option C: Any OpenAI-compatible API directly ---
#
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
